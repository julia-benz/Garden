function renderFertTasks(bed, containerId) {
  const container = document.getElementById(containerId);
  if (!container) return;
  container.innerHTML = '';
  fertTasks[bed].forEach(task => {
    const checked = state.fertChecks[task.id] || false;
    const div = document.createElement('div');
    div.className = 'fert-task' + (checked ? ' done' : '');
    div.id = 'ft-' + task.id;
    div.innerHTML = `
      <input type="checkbox" ${checked ? 'checked' : ''} onchange="toggleFert('${task.id}',this)">
      <div>
        <div class="task-text">${task.text} <span class="fert-badge ${task.badge}">${task.badge === 'fb-511' ? '5-1-1' : task.badge === 'fb-mg' ? 'Miracle-Gro' : 'Tomato-Tone'}</span></div>
        <div class="task-meta">${task.meta}</div>
      </div>`;
    container.appendChild(div);
  });
}

function toggleFert(id, cb) {
  state.fertChecks[id] = cb.checked;
  const row = document.getElementById('ft-' + id);
  if (row) row.className = 'fert-task' + (cb.checked ? ' done' : '');
  saveState(state);
}

function toggleSwitch(cb, id) {
  state.switches[id] = cb.checked;
  const el = document.getElementById(id);
  if (el) el.className = 'switch-alert' + (cb.checked ? ' done' : '');
  saveState(state);
}

// Restore switch states
function restoreSwitches() {
  ['sw-turtle','sw-parrot','sw-marigold','sw-mountain','sw-gate','sw-rosebush','sw-rosependulina','sw-roseofsharon'].forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    const cb = el.querySelector('input[type=checkbox]');
    if (state.switches[id]) { if(cb) cb.checked = true; el.className = 'switch-alert done'; }
  });
}

