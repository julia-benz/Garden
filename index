function renderWaterChecks() {
  const container = document.getElementById('waterChecks');
  if (!container) return;
  container.innerHTML = '';
  waterCheckItems.forEach(item => {
    const checked = state.waterChecks[item.id] || false;
    const div = document.createElement('div');
    div.className = 'fert-task' + (checked ? ' done' : '');
    div.id = 'wc-' + item.id;
    div.innerHTML = `
      <input type="checkbox" ${checked ? 'checked' : ''} onchange="toggleWater('${item.id}',this)">
      <div class="task-text">${item.text}</div>`;
    container.appendChild(div);
  });
  const resetBtn = document.createElement('button');
  resetBtn.className = 'btn btn-sm';
  resetBtn.style.marginTop = '10px';
  resetBtn.textContent = '🔄 Reset Weekly Checks';
  resetBtn.onclick = () => {
    waterCheckItems.forEach(i => { state.waterChecks[i.id] = false; });
    saveState(state);
    renderWaterChecks();
  };
  container.appendChild(resetBtn);
}

function toggleWater(id, cb) {
  state.waterChecks[id] = cb.checked;
  const row = document.getElementById('wc-' + id);
  if (row) row.className = 'fert-task' + (cb.checked ? ' done' : '');
  saveState(state);
}

