function setPhoto(bedId, url) {
  if (!url || !url.trim()) return;
  const wrap = document.getElementById('photo-' + bedId);
  if (!wrap) return;
  wrap.innerHTML = `<img src="${url.trim()}" alt="${bedId} photo" onerror="this.parentNode.innerHTML='<div class=\\'bed-photo-placeholder\\'><div class=\\'ph-icon\\'>❌</div><div>Image failed to load — check the URL</div></div>'">`;
  if (!state.photos) state.photos = {};
  state.photos[bedId] = url.trim();
  saveState(state);
}

function restorePhotos() {
  if (!state.photos) return;
  Object.entries(state.photos).forEach(([bedId, url]) => {
    const input = document.getElementById('img-' + bedId);
    if (input) input.value = url;
    setPhoto(bedId, url);
  });
}

