<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🌱 Julia's Garden HQ</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Mono:wght@400;500&family=Lato:wght@300;400;700&display=swap');

  :root {
    --soil: #3d2b1f;
    --moss: #4a5e3a;
    --sage: #7a9e6e;
    --mint: #a8c89a;
    --cream: #f5f0e8;
    --petal: #e8d5b0;
    --tomato: #c0392b;
    --pepper: #e67e22;
    --goth: #2c2c3e;
    --goth-accent: #7c6f9e;
    --turtle: #3d6b4f;
    --parrot: #b8581d;
    --sun: #f39c12;
    --water: #5b9bd5;
    --gold: #d4ac0d;
    --shadow: rgba(0,0,0,0.15);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Lato', sans-serif;
    background: var(--soil);
    background-image: 
      radial-gradient(ellipse at 20% 0%, #5a3825 0%, transparent 50%),
      radial-gradient(ellipse at 80% 100%, #2a1a10 0%, transparent 50%);
    min-height: 100vh;
    color: var(--cream);
  }

  /* ── HEADER ── */
  header {
    background: linear-gradient(135deg, var(--moss) 0%, #2d3d22 100%);
    border-bottom: 3px solid var(--sage);
    padding: 20px 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
  }
  header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: var(--mint);
    letter-spacing: 1px;
  }
  header p { color: var(--petal); font-size: 0.85rem; margin-top: 2px; }

  .stats-bar {
    display: flex; gap: 16px; flex-wrap: wrap; margin-top: 12px;
  }
  .stat-pill {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 0.78rem;
    color: var(--mint);
    font-family: 'DM Mono', monospace;
  }

  /* ── NAV TABS ── */
  .nav-tabs {
    display: flex; gap: 0; overflow-x: auto;
    background: rgba(0,0,0,0.3);
    border-bottom: 2px solid var(--moss);
    padding: 0 16px;
  }
  .nav-tab {
    padding: 12px 18px;
    cursor: pointer;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--petal);
    border-bottom: 3px solid transparent;
    white-space: nowrap;
    transition: all 0.2s;
    background: none; border-top: none; border-left: none; border-right: none;
  }
  .nav-tab:hover { color: var(--mint); }
  .nav-tab.active { color: var(--mint); border-bottom-color: var(--sage); }

  /* ── MAIN CONTENT ── */
  .main { padding: 20px 16px; max-width: 1100px; margin: 0 auto; }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* ── CARDS ── */
  .card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
  }
  .card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: var(--mint);
    margin-bottom: 12px;
    display: flex; align-items: center; gap: 8px;
  }

  /* ── BED CARDS ── */
  .bed-card {
    border-radius: 14px;
    padding: 20px;
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
  }
  .bed-turtle { background: linear-gradient(135deg, #1e3d2a, #2d5a3d); border: 2px solid #4a9e6e; }
  .bed-parrot { background: linear-gradient(135deg, #3d2010, #5a3018); border: 2px solid var(--pepper); }
  .bed-goth { background: linear-gradient(135deg, #1a1a2e, #2c2c45); border: 2px solid var(--goth-accent); }
  .bed-herbs { background: linear-gradient(135deg, #2a3d1e, #3a5028); border: 2px solid var(--sage); }

  .bed-badge {
    display: inline-block;
    padding: 3px 12px;
    border-radius: 20px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .badge-turtle { background: var(--turtle); color: #fff; }
  .badge-parrot { background: var(--parrot); color: #fff; }
  .badge-goth { background: var(--goth-accent); color: #fff; }
  .badge-herbs { background: var(--moss); color: #fff; }

  .bed-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    margin-bottom: 4px;
  }
  .bed-subtitle { font-size: 0.8rem; opacity: 0.7; margin-bottom: 16px; }

  /* ── BED DIAGRAM ── */
  .bed-diagram {
    background: rgba(0,0,0,0.25);
    border-radius: 10px;
    padding: 14px;
    margin: 12px 0;
    position: relative;
    overflow: hidden;
  }
  .diagram-grid {
    display: grid;
    gap: 6px;
    margin: 0 auto;
  }
  .plant-slot {
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    cursor: pointer;
    transition: transform 0.2s;
    border: 2px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.05);
    aspect-ratio: 1;
    position: relative;
  }
  .plant-slot:hover { transform: scale(1.15); z-index: 10; }
  .plant-slot .tooltip {
    display: none;
    position: absolute;
    bottom: 110%;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.9);
    color: #fff;
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 0.7rem;
    white-space: nowrap;
    z-index: 20;
    pointer-events: none;
  }
  .plant-slot:hover .tooltip { display: block; }

  .diagram-label {
    font-size: 0.7rem;
    color: var(--petal);
    text-align: center;
    margin-top: 8px;
    font-family: 'DM Mono', monospace;
  }

  /* ── FERTILIZER CHECKLIST ── */
  .fert-task {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 12px;
    background: rgba(0,0,0,0.2);
    border-radius: 8px;
    margin-bottom: 8px;
    transition: background 0.2s;
  }
  .fert-task.done { opacity: 0.5; }
  .fert-task.done .task-text { text-decoration: line-through; }

  .fert-task input[type=checkbox] {
    width: 18px; height: 18px; accent-color: var(--sage);
    flex-shrink: 0; margin-top: 2px; cursor: pointer;
  }
  .task-text { font-size: 0.85rem; line-height: 1.4; }
  .task-meta {
    font-size: 0.72rem;
    color: var(--sage);
    font-family: 'DM Mono', monospace;
    margin-top: 2px;
  }
  .fert-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 0.68rem;
    font-weight: 700;
    margin-left: 6px;
  }
  .fb-511 { background: #4a7c59; color: #fff; }
  .fb-mg { background: #2874a6; color: #fff; }
  .fb-tt { background: #922b21; color: #fff; }

  /* ── SWITCH FERTILIZER CHECKBOX ── */
  .switch-alert {
    background: rgba(240, 180, 0, 0.15);
    border: 1px solid var(--gold);
    border-radius: 8px;
    padding: 10px 14px;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.83rem;
  }
  .switch-alert input[type=checkbox] { accent-color: var(--gold); width: 18px; height: 18px; }
  .switch-alert.done { opacity: 0.5; }

  /* ── SPROUTING / FRUITING TABLE ── */
  .timeline-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
  }
  .timeline-table th {
    background: rgba(255,255,255,0.08);
    padding: 8px 12px;
    text-align: left;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--sage);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .timeline-table td {
    padding: 8px 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    vertical-align: top;
  }
  .timeline-table tr:hover td { background: rgba(255,255,255,0.04); }
  .date-chip {
    background: rgba(90,155,213,0.2);
    border: 1px solid rgba(90,155,213,0.4);
    border-radius: 6px;
    padding: 2px 8px;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: #8ec6f0;
  }

  /* ── WATERING ── */
  .water-card {
    background: rgba(91,155,213,0.08);
    border: 1px solid rgba(91,155,213,0.25);
    border-radius: 10px;
    padding: 14px 16px;
    margin-bottom: 10px;
  }
  .water-title {
    font-weight: 700;
    font-size: 0.9rem;
    color: #8ec6f0;
    margin-bottom: 4px;
  }
  .water-detail { font-size: 0.8rem; color: var(--petal); }
  .drip-badge {
    display: inline-block;
    background: rgba(91,155,213,0.2);
    border: 1px solid rgba(91,155,213,0.4);
    border-radius: 12px;
    padding: 2px 10px;
    font-size: 0.7rem;
    color: #8ec6f0;
    font-family: 'DM Mono', monospace;
    margin-left: 8px;
  }

  /* ── PLANTING LOG TABLE ── */
  .log-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }
  .log-table th {
    background: var(--moss);
    padding: 8px 10px;
    text-align: left;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--mint);
    white-space: nowrap;
  }
  .log-table td {
    padding: 7px 10px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    vertical-align: top;
  }
  .log-table tr:hover td { background: rgba(255,255,255,0.04); }
  .log-table td input, .log-table td textarea {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 4px;
    color: var(--cream);
    padding: 4px 6px;
    font-size: 0.75rem;
    font-family: 'Lato', sans-serif;
    width: 100%;
  }
  .log-table td textarea { resize: vertical; min-height: 40px; }

  /* ── ADD ROW BUTTON ── */
  .btn {
    background: var(--moss);
    color: var(--mint);
    border: 1px solid var(--sage);
    border-radius: 8px;
    padding: 8px 16px;
    font-size: 0.82rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Lato', sans-serif;
  }
  .btn:hover { background: var(--sage); color: var(--soil); }
  .btn-sm { padding: 4px 10px; font-size: 0.72rem; }
  .btn-danger { background: rgba(192,57,43,0.3); border-color: var(--tomato); color: #ff8a7a; }
  .btn-danger:hover { background: var(--tomato); color: #fff; }

  /* ── AI CHAT ── */
  .chat-container {
    background: rgba(0,0,0,0.25);
    border-radius: 10px;
    padding: 16px;
    margin-bottom: 12px;
    max-height: 400px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .chat-msg {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }
  .chat-avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .avatar-user { background: var(--moss); }
  .avatar-ai { background: var(--goth-accent); }
  .chat-bubble {
    background: rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 0.83rem;
    line-height: 1.5;
    max-width: 85%;
    flex: 1;
  }
  .chat-bubble.user { background: rgba(74,94,58,0.3); }
  .chat-meta { font-size: 0.68rem; color: var(--sage); margin-top: 4px; font-family: 'DM Mono', monospace; }

  .chat-input-row {
    display: flex; gap: 8px; align-items: flex-end;
  }
  .chat-input-row textarea {
    flex: 1;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: var(--cream);
    padding: 10px 12px;
    font-size: 0.83rem;
    font-family: 'Lato', sans-serif;
    resize: none;
    min-height: 44px;
    max-height: 120px;
  }
  .chat-input-row textarea:focus { outline: none; border-color: var(--sage); }

  .saved-qa {
    background: rgba(0,0,0,0.2);
    border-left: 3px solid var(--goth-accent);
    border-radius: 0 8px 8px 0;
    padding: 10px 14px;
    margin-bottom: 8px;
    font-size: 0.8rem;
  }
  .saved-qa .sq { font-weight: 700; color: var(--mint); margin-bottom: 4px; }
  .saved-qa .sa { color: var(--petal); }
  .saved-qa .sm { font-size: 0.68rem; color: var(--sage); font-family: 'DM Mono', monospace; margin-top: 4px; }

  /* ── NOTES ── */
  .notes-area {
    width: 100%;
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    color: var(--cream);
    padding: 12px 14px;
    font-size: 0.83rem;
    font-family: 'Lato', sans-serif;
    line-height: 1.6;
    resize: vertical;
    min-height: 140px;
  }
  .notes-area:focus { outline: none; border-color: var(--sage); }

  /* ── TODO CHECKLIST ── */
  .todo-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px;
    background: rgba(0,0,0,0.15);
    border-radius: 8px;
    margin-bottom: 6px;
    transition: background 0.2s;
  }
  .todo-item.done { opacity: 0.5; }
  .todo-item.done span { text-decoration: line-through; }
  .todo-item input[type=checkbox] { accent-color: var(--sage); width: 16px; height: 16px; cursor: pointer; }
  .todo-item span { font-size: 0.83rem; flex: 1; }
  .todo-priority {
    font-size: 0.68rem;
    padding: 2px 8px;
    border-radius: 10px;
    font-weight: 700;
  }
  .p-high { background: rgba(192,57,43,0.3); color: #ff8a7a; }
  .p-med { background: rgba(230,126,34,0.3); color: #ffb87a; }
  .p-low { background: rgba(74,94,58,0.3); color: var(--mint); }

  /* ── SUCCESSIVE PLANTING ALERT ── */
  .succ-alert {
    background: rgba(212,172,13,0.12);
    border: 1px solid rgba(212,172,13,0.4);
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 10px;
    font-size: 0.82rem;
  }
  .succ-alert strong { color: var(--gold); }

  /* ── SECTION DIVIDER ── */
  .section-divider {
    display: flex; align-items: center; gap: 10px;
    margin: 20px 0 14px;
  }
  .section-divider span {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    color: var(--sage);
    white-space: nowrap;
  }
  .section-divider::before, .section-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,0.1);
  }

  /* ── LOADING SPINNER ── */
  .spinner {
    display: inline-block;
    width: 16px; height: 16px;
    border: 2px solid rgba(255,255,255,0.2);
    border-top-color: var(--sage);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    vertical-align: middle;
    margin-right: 6px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── RESPONSIVE ── */
  @media (max-width: 600px) {
    header h1 { font-size: 1.4rem; }
    .nav-tab { padding: 10px 12px; font-size: 0.75rem; }
    .main { padding: 12px 10px; }
  }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
  ::-webkit-scrollbar-thumb { background: var(--moss); border-radius: 3px; }

  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 700px) { .grid-2 { grid-template-columns: 1fr; } }

  .tag { display: inline-block; background: rgba(255,255,255,0.08); border-radius: 4px; padding: 1px 7px; font-size: 0.7rem; margin: 1px; font-family: 'DM Mono', monospace; }
</style>
</head>
<body>

<header>
  <h1>🌱 Julia's Garden HQ</h1>
  <p>Longmont, CO · Season 2025 · Drip on veggie beds · Manual herbs & flowers</p>
  <div class="stats-bar" id="statsBar">
    <span class="stat-pill">🍅 Tomatoes: 8 varieties</span>
    <span class="stat-pill">🌿 Herbs: 10 plants</span>
    <span class="stat-pill">🌶️ Peppers: 9 varieties planted</span>
    <span class="stat-pill">🌸 Flowers: Mountain Bed + Marigolds</span>
    <span class="stat-pill">🛏️ Beds: 4 + Herb Trellis</span>
  </div>
</header>

<div class="nav-tabs">
  <button class="nav-tab active" onclick="showTab('beds')">🛏️ Beds</button>
  <button class="nav-tab" onclick="showTab('flowers')">🌸 Flowers</button>
  <button class="nav-tab" onclick="showTab('fertilizer')">🌿 Fertilizer</button>
  <button class="nav-tab" onclick="showTab('timeline')">📅 Timeline</button>
  <button class="nav-tab" onclick="showTab('watering')">💧 Watering</button>
  <button class="nav-tab" onclick="showTab('log')">📋 Planting Log</button>
  <button class="nav-tab" onclick="showTab('ai')">🤖 AI Garden Chat</button>
  <button class="nav-tab" onclick="showTab('notes')">📝 Notes</button>
  <button class="nav-tab" onclick="showTab('todo')">✅ To-Do</button>
</div>

<div class="main">

