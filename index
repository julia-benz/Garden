async function sendChat() {
  const input = document.getElementById('chatInput');
  const msg = input.value.trim();
  if (!msg) return;

  addChatMsg('user', msg);
  input.value = '';

  const chatBtn = document.getElementById('chatBtn');
  chatBtn.disabled = true;
  chatBtn.innerHTML = '<span class="spinner"></span>';

  state.chatHistory.push({ role:'user', content: msg });
  if (state.chatHistory.length > 20) state.chatHistory = state.chatHistory.slice(-20);

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        system: SYSTEM,
        messages: state.chatHistory
      })
    });
    const data = await res.json();
    const reply = data.content?.find(b=>b.type==='text')?.text || 'Sorry, I had trouble with that.';
    state.chatHistory.push({ role:'assistant', content: reply });
    saveState(state);
    addChatMsg('ai', reply);
    lastQA = { q: msg, a: reply, date: new Date().toLocaleDateString() };
  } catch(e) {
    addChatMsg('ai', '❌ Error reaching AI. Check your connection and try again.');
  }

  chatBtn.disabled = false;
  chatBtn.innerHTML = 'Send 🌿';
}

function addChatMsg(role, text) {
  const container = document.getElementById('chatContainer');
  const div = document.createElement('div');
  div.className = 'chat-msg';
  div.innerHTML = `
    <div class="chat-avatar ${role === 'user' ? 'avatar-user' : 'avatar-ai'}">${role === 'user' ? '👩' : '🌱'}</div>
    <div class="chat-bubble ${role === 'user' ? 'user' : ''}">
      ${text.replace(/\n/g,'<br>')}
      <div class="chat-meta">${role === 'user' ? 'You' : 'Garden AI'} · ${new Date().toLocaleTimeString()}</div>
    </div>`;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
}

function saveLastQA() {
  if (!lastQA) { alert('Send a message first!'); return; }
  state.savedQA.unshift(lastQA);
  saveState(state);
  renderSavedQA();
  document.getElementById('savedQACard').style.display = 'block';
  alert('📌 Q&A saved!');
}

function renderSavedQA() {
  const list = document.getElementById('savedQAList');
  if (!list) return;
  if (!state.savedQA.length) { list.innerHTML = '<p style="font-size:0.8rem;color:var(--petal);">No saved Q&As yet.</p>'; return; }
  list.innerHTML = '';
  state.savedQA.forEach((qa, i) => {
    const div = document.createElement('div');
    div.className = 'saved-qa';
    div.innerHTML = `
      <div class="sq">Q: ${qa.q}</div>
      <div class="sa">${qa.a.replace(/\n/g,'<br>')}</div>
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <div class="sm">${qa.date}</div>
        <button class="btn btn-sm btn-danger" onclick="deleteQA(${i})">✕</button>
      </div>`;
    list.appendChild(div);
  });
  document.getElementById('savedQACard').style.display = 'block';
}

function deleteQA(i) {
  state.savedQA.splice(i, 1);
  saveState(state);
  renderSavedQA();
}

