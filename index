function renderLog() {
  const tbody = document.getElementById('logBody');
  if (!tbody) return;
  tbody.innerHTML = '';
  state.log.forEach((row, i) => {
    const tr = document.createElement('tr');
    const fields = ['plant','bed','date','soil','start','source','fert','notes'];
    fields.forEach(f => {
      const td = document.createElement('td');
      if (f === 'notes') {
        td.innerHTML = `<textarea onchange="updateLog(${i},'${f}',this.value)">${row[f]||''}</textarea>`;
      } else {
        td.innerHTML = `<input value="${(row[f]||'').replace(/"/g,'&quot;')}" onchange="updateLog(${i},'${f}',this.value)">`;
      }
      tr.appendChild(td);
    });
    const tdDel = document.createElement('td');
    tdDel.innerHTML = `<button class="btn btn-sm btn-danger" onclick="deleteLogRow(${i})">✕</button>`;
    tr.appendChild(tdDel);
    tbody.appendChild(tr);
  });
}

function updateLog(i, field, val) {
  state.log[i][field] = val;
  saveState(state);
}

function addLogRow() {
  state.log.push({ plant:'', bed:'', date:'', soil:'', start:'', source:'', fert:'', notes:'' });
  saveState(state);
  renderLog();
}

function deleteLogRow(i) {
  if (!confirm('Delete this row?')) return;
  state.log.splice(i, 1);
  saveState(state);
  renderLog();
}

function saveLog() {
  saveState(state);
  alert('✅ Log saved!');
}

function exportLog() {
  const headers = ['Plant','Bed','Date','Soil','Start','Source','Fertilizer','Notes'];
  const rows = state.log.map(r => [r.plant,r.bed,r.date,r.soil,r.start,r.source,r.fert,r.notes].map(v => `"${(v||'').replace(/"/g,'""')}"`).join(','));
  const csv = [headers.join(','), ...rows].join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv,' + encodeURIComponent(csv);
  a.download = 'garden-log-2025.csv';
  a.click();
}

